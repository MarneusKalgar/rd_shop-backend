# Application
APP=shop
PORT=4000
NODE_ENV=development
NODE_HOSTNAME=localhost
API_URL=http://localhost:4000
# Only used to enable seeding in production, should be set to false in production
ALLOW_SEED_IN_PRODUCTION=false

# Database (Neon Cloud)
DATABASE_URL='postgresql://<username>:<password>@<host>:<port>/<database>?sslmode=require&channel_binding=require'
DATABASE_PROVIDER=neon

# Database (Local PostgreSQL via Docker Compose)
DATABASE_PROVIDER=postgres
DATABASE_HOST=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rd_shop_dev
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/rd_shop_dev

# Logging
# Valid values: error, warn, log, debug, verbose
# Default: log
APP_LOG_LEVEL=log

# Concurrency Test
CONCURRENCY_TEST_PRODUCT_ID=
CONCURRENCY_TEST_USER_ID=
CONCURRENCY_TEST_REQUESTS=30

# Auth
# Used to build email verification and password reset links
APP_URL=http://localhost:3000

# AWS SES (email sending)
# When AWS_SES_REGION is not set, emails are logged to console (dev mode)
AWS_SES_REGION=
SES_FROM_ADDRESS=noreply@rdshop.com
EMAIL_VERIFICATION_EXPIRES_IN=24h

JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=10m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# AWS (MinIO | Cloudflare R2)
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=true
AWS_CLOUDFRONT_URL=
AWS_S3_PRESIGNED_URL_EXPIRATION=900
AWS_S3_PRESIGNED_URL_DOWNLOAD_EXPIRATION=3600
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_VHOST=/
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_SIMULATE_DELAY=1000
RABBITMQ_SIMULATE_FAILURE=false
RABBITMQ_SIMULATE_DUPLICATE_MESSAGE_ID=
RABBITMQ_DISABLE_PAYMENTS_AUTHORIZATION=false

# GRPC
PAYMENTS_GRPC_HOST=payments
PAYMENTS_GRPC_PORT=5001
PAYMENTS_GRPC_TIMEOUT_MS=5000
