{
  "name": "shop",
  "version": "1.0.0",
  "description": "Backend for RD Shop application",
  "main": "index.js",
  "scripts": {
    "start:dev": "cd ../.. && npm run build:common && NODE_ENV=development APP=shop nest start shop --watch",
    "start:debug": "NODE_ENV=development nest start --debug --watch",
    "start:prod": "node ../../dist/apps/shop/main",
    "typeorm": "NODE_ENV=development APP=shop TS_NODE_PROJECT=tsconfig.app.json ts-node -r tsconfig-paths/register ../../node_modules/typeorm/cli.js",
    "db:generate": "npm run typeorm -- migration:generate -d ./src/data-source.ts",
    "db:migrate:dev": "npm run typeorm -- migration:run -d ./src/data-source.ts",
    "db:migrate:prod": "NODE_ENV=production APP=shop node ../../node_modules/typeorm/cli.js migration:run -d ../../dist/apps/shop/data-source.js",
    "db:revert:dev": "npm run typeorm -- migration:revert -d ./src/data-source.ts",
    "db:revert:prod": "NODE_ENV=production APP=shop node ../../node_modules/typeorm/cli.js migration:revert -d ../../dist/apps/shop/data-source.js",
    "db:seed:dev": "NODE_ENV=development APP=shop ts-node -r tsconfig-paths/register ./src/db/seed/index.ts",
    "db:seed:prod": "NODE_ENV=production APP=shop node ../../dist/apps/shop/db/seed/prod.js",
    "db:stage-validation:cleanup:prod": "NODE_ENV=production APP=shop node ../../dist/apps/shop/db/stage-validation/cleanup.js",
    "db:stage-validation:seed:prod": "NODE_ENV=production APP=shop node ../../dist/apps/shop/db/stage-validation/seed.js",
    "docker:build:dev": "bash scripts/docker/dev-compose.sh up --build",
    "docker:start:dev": "bash scripts/docker/dev-compose.sh up",
    "docker:db:generate:dev": "bash scripts/docker/dev-compose.sh exec -w /app/apps/shop shop npm run db:generate --",
    "docker:migrate:dev": "bash scripts/docker/dev-migrate.sh",
    "docker:migrate:dev:rebuild": "bash scripts/docker/dev-migrate.sh --build",
    "docker:seed:dev": "bash scripts/docker/dev-seed.sh",
    "docker:seed:dev:rebuild": "bash scripts/docker/dev-seed.sh --build",
    "docker:down:dev": "bash scripts/docker/dev-compose.sh down",
    "test:perf": "rm -rf test/performance/results/db-profiling && jest --config test/jest-perf.json --runInBand",
    "test:e2e": "jest --config test/jest-e2e.json --runInBand",
    "e2e:fresh": "npm run e2e:up && npm run e2e:migrate && npm run e2e:seed && npm run e2e:app || npm run e2e:down",
    "e2e:up": "docker compose -p rd_shop_e2e -f compose.e2e.yml up -d postgres-shop-e2e postgres-payments-e2e rabbitmq-e2e minio-e2e && docker compose -p rd_shop_e2e -f compose.e2e.yml --profile init run --rm minio-init-e2e",
    "e2e:migrate": "bash test/e2e/scripts/e2e-migrate.sh",
    "e2e:seed": "bash test/e2e/scripts/e2e-seed.sh",
    "e2e:app": "docker compose -p rd_shop_e2e -f compose.e2e.yml --profile app up -d",
    "e2e:logs": "docker compose -p rd_shop_e2e -f compose.e2e.yml --profile app logs -f",
    "e2e:down": "docker compose -p rd_shop_e2e -f compose.e2e.yml --profile app down -v --remove-orphans --rmi local",
    "perf:fresh": "npm run perf:up && npm run perf:migrate && npm run perf:seed && npm run perf:app",
    "perf:fresh:unconstrained": "npm run perf:up && npm run perf:migrate && npm run perf:seed && npm run perf:app:unconstrained",
    "perf:fresh:grpc-breaker": "npm run perf:up && npm run perf:migrate && npm run perf:seed && npm run perf:app:grpc-breaker:rebuild",
    "perf:up": "docker compose -p rd_shop_perf -f compose.perf.yml up -d postgres-perf rabbitmq-perf",
    "perf:migrate": "bash test/performance/scripts/perf-migrate.sh",
    "perf:seed": "bash test/performance/scripts/perf-seed.sh",
    "perf:app": "docker compose --compatibility -p rd_shop_perf -f compose.perf.yml --profile app up shop-perf",
    "perf:app:rebuild": "docker compose --compatibility -p rd_shop_perf -f compose.perf.yml --profile app up --build shop-perf",
    "perf:app:grpc-breaker": "bash test/performance/scripts/perf-app-grpc-breaker.sh",
    "perf:app:grpc-breaker:rebuild": "bash test/performance/scripts/perf-app-grpc-breaker.sh --build",
    "perf:app:unconstrained": "docker compose -p rd_shop_perf -f compose.perf.yml --profile app-unconstrained up shop-perf-unconstrained",
    "perf:app:unconstrained:rebuild": "docker compose -p rd_shop_perf -f compose.perf.yml --profile app-unconstrained up --build shop-perf-unconstrained",
    "perf:baseline:search": "k6 run --out json=test/performance/results/k6/product-search-baseline.json test/performance/scenarios/k6/product-search.js",
    "perf:baseline:orders": "k6 run --out json=test/performance/results/k6/order-flow-baseline.json test/performance/scenarios/k6/order-flow.js",
    "perf:baseline:auth": "k6 run --out json=test/performance/results/k6/auth-flow-baseline.json test/performance/scenarios/k6/auth-flow.js",
    "perf:baseline:signin": "k6 run --out json=test/performance/results/k6/signin-stress-baseline.json test/performance/scenarios/k6/signin-stress.js",
    "perf:after:search": "k6 run --out json=test/performance/results/k6/product-search-after-a1.json test/performance/scenarios/k6/product-search-after-a1.js",
    "perf:after:pagination": "k6 run --out json=test/performance/results/k6/product-pagination-after-a2.json test/performance/scenarios/k6/product-pagination-after-a2.js",
    "perf:after:orders": "k6 run --out json=test/performance/results/k6/order-flow-after-a3.json test/performance/scenarios/k6/order-flow-after-a3.js",
    "perf:after:orders:b4": "k6 run --out json=test/performance/results/k6/order-flow-after-b4.json test/performance/scenarios/k6/order-flow-after-b4.js",
    "perf:after:signin": "k6 run --out json=test/performance/results/k6/signin-stress-after-b1.json test/performance/scenarios/k6/signin-stress-after-b1.js",
    "perf:after:auth:b1": "k6 run --out json=test/performance/results/k6/auth-flow-after-b1.json test/performance/scenarios/k6/auth-flow-after-b1.js",
    "perf:after:auth:b5": "k6 run --out json=test/performance/results/k6/auth-flow-after-b5.json test/performance/scenarios/k6/auth-flow-after-b5.js",
    "perf:grpc-breaker:before": "k6 run --env PERF_K6_DURATION=60s --out json=test/performance/results/k6/order-flow-grpc-breaker-before.json test/performance/scenarios/k6/order-flow-after-b4.js",
    "perf:grpc-breaker:after": "k6 run --env PERF_K6_DURATION=60s --out json=test/performance/results/k6/order-flow-grpc-breaker-after.json test/performance/scenarios/k6/order-flow-after-b4.js",
    "perf:down": "docker compose -p rd_shop_perf -f compose.perf.yml down -v --remove-orphans"
  },
  "keywords": [],
  "author": "Ihor Chernobai",
  "license": "ISC"
}
