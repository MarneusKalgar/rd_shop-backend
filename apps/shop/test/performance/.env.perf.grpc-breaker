# grpc-breaker overrides — applied on top of .env.perf for the app-grpc-breaker compose profile only.
# Points the order-worker at the gRPC stub (hangs all RPCs) and enables payment
# authorization so the circuit breaker path is exercised.
PAYMENTS_GRPC_HOST=grpc-stub-perf
RABBITMQ_DISABLE_PAYMENTS_AUTHORIZATION=false
OBSERVABILITY_METRICS_ENABLED=false
