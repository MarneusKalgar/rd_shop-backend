APP=shop
AWS_ACCESS_KEY_ID=perf-key-id
AWS_REGION=eu-central-1
AWS_S3_BUCKET=perf-bucket
AWS_SECRET_ACCESS_KEY=perf-secret-key

# k6 target — override to point at a remote env
BASE_URL=http://localhost:8090
BCRYPT_SALT_ROUNDS=10
DATABASE_PROVIDER=postgres
TOKEN_HMAC_SECRET=6d6873b4d7ee383bd7c4245abfabef6acdff73c43354f65d5bb7536467412342

# Docker Compose: internal service hostname.
# Testcontainers: bootstrapPerfTest() overrides DATABASE_URL with the mapped container URL.
DATABASE_URL=postgres://perf:perf@postgres-perf:5432/rd_shop_perf?sslmode=disable
DB_SLOW_QUERY_THRESHOLD_MS=100
EVENT_LOOP_LAG_THRESHOLD_MS=50
JWT_ACCESS_EXPIRES_IN=1h
JWT_ACCESS_SECRET=perf-jwt-secret-not-for-production
JWT_REFRESH_EXPIRES_IN=7d

# Testcontainers uses test; compose services override to production inline
NODE_ENV=test
PAYMENTS_GRPC_HOST=payments-perf
PAYMENTS_GRPC_PORT=5001
PAYMENTS_GRPC_TIMEOUT_MS=5000

# Docker Compose exposes shop-perf on 8090; Testcontainers does not start HTTP server
PORT=8090
POSTGRES_DB=rd_shop_perf
POSTGRES_PASSWORD=perf
POSTGRES_USER=perf
RABBITMQ_DISABLE_PAYMENTS_AUTHORIZATION=true

# Docker Compose: internal service hostname; Testcontainers mocks the RabbitMQ module
RABBITMQ_HOST=rabbitmq-perf
RABBITMQ_PASSWORD=guest
RABBITMQ_PORT=5672
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_USER=guest
RABBITMQ_VHOST=/
THROTTLE_SKIP=true
