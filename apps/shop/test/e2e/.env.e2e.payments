# ============================================================================
# E2E environment — payments service + payments postgres
# ============================================================================
# Used by: postgres-payments-e2e, migrate-payments-e2e, payments-e2e
# ============================================================================

# Application
APP=payments
NODE_ENV=production
ALLOW_SEED_IN_PRODUCTION=true
OBSERVABILITY_METRICS_ENABLED=false

# gRPC server
PAYMENTS_GRPC_HOST=0.0.0.0
PAYMENTS_GRPC_PORT=5001

# Database (payments)
DATABASE_PROVIDER=postgres
DATABASE_URL=postgresql://postgres:postgres@postgres-payments-e2e:5432/rd_shop_payments_e2e?sslmode=disable
DATABASE_HOST=postgres-payments-e2e
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rd_shop_payments_e2e
