# ============================================================================
# E2E environment — shop service + shop postgres + rabbitmq + minio
# ============================================================================
# Used by: postgres-shop-e2e, migrate-shop-e2e, seed-shop-e2e, shop-e2e
#          and by test/e2e/test-env-setup.ts (loaded into Jest process)
# ============================================================================

# Application
APP=shop
NODE_ENV=production
PORT=8080
ALLOW_SEED_IN_PRODUCTION=true
OBSERVABILITY_METRICS_ENABLED=false

# Database (shop)
DATABASE_PROVIDER=postgres
DATABASE_URL=postgresql://postgres:postgres@postgres-shop-e2e:5432/rd_shop_e2e?sslmode=disable
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rd_shop_e2e

# RabbitMQ
RABBITMQ_HOST=rabbitmq-e2e
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# Payments gRPC
PAYMENTS_GRPC_HOST=payments-e2e
PAYMENTS_GRPC_PORT=5001

# S3 / MinIO
AWS_S3_ENDPOINT=http://minio-e2e:9000
AWS_S3_BUCKET=rd-shop-files-e2e
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=eu-central-1
AWS_S3_FORCE_PATH_STYLE=true

# Auth
JWT_ACCESS_SECRET=e2e-test-jwt-secret-at-least-32-chars!
TOKEN_HMAC_SECRET=e2e-hmac-secret-32chars-padding-ok1

# Behaviour tuning for e2e
BCRYPT_SALT_ROUNDS=4
RABBITMQ_SIMULATE_DELAY=0
RABBITMQ_SIMULATE_FAILURE=false
RABBITMQ_DISABLE_PAYMENTS_AUTHORIZATION=false
THROTTLE_SKIP=true

# Host-side URL used by the Jest test runner to reach shop-e2e
STAGE_VALIDATION_BASE_URL=http://localhost:8092
