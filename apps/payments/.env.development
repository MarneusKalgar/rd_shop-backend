# Application
APP=payments
NODE_ENV=development

# GRPC Server Configuration
PAYMENTS_GRPC_HOST=0.0.0.0
PAYMENTS_GRPC_PORT=5001

# Database - Local PostgreSQL (via Docker Compose)
DATABASE_PROVIDER=postgres
DATABASE_HOST=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rd_shop_payments_dev
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/rd_shop_payments_dev
