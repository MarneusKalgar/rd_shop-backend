{
  "name": "payments",
  "version": "1.0.0",
  "description": "Backend for RD Shop Payments service",
  "main": "index.js",
  "scripts": {
    "start:dev": "cd ../.. && npm run build:common && NODE_ENV=development APP=payments nest start payments --watch",
    "start:prod": "node ../../dist/apps/payments/main",
    "typeorm": "NODE_ENV=development APP=payments TS_NODE_PROJECT=tsconfig.app.json ts-node -r tsconfig-paths/register ../../node_modules/typeorm/cli.js",
    "db:generate": "npm run typeorm -- migration:generate -d ./src/data-source.ts",
    "db:migrate:dev": "npm run typeorm -- migration:run -d ./src/data-source.ts",
    "db:migrate:prod": "NODE_ENV=production APP=payments node ../../node_modules/typeorm/cli.js migration:run -d ../../dist/apps/payments/data-source.js",
    "db:revert:dev": "npm run typeorm -- migration:revert -d ./src/data-source.ts",
    "db:revert:prod": "NODE_ENV=production APP=payments node ../../node_modules/typeorm/cli.js migration:revert -d ../../dist/apps/payments/data-source.js",
    "docker:build:dev": "bash scripts/docker/dev-compose.sh up --build",
    "docker:start:dev": "bash scripts/docker/dev-compose.sh up",
    "docker:migrate:dev": "bash scripts/docker/dev-migrate.sh",
    "docker:migrate:dev:rebuild": "bash scripts/docker/dev-migrate.sh --build",
    "docker:down:dev": "bash scripts/docker/dev-compose.sh down"
  },
  "keywords": [],
  "author": "Ihor Chernobai",
  "license": "ISC"
}
