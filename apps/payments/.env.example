# ============================================================================
# RD PAYMENTS SERVICE — Environment Configuration Template
# ============================================================================
# Copy this file to .env.development or .env.production and fill in values.
# All variables are required unless marked [OPTIONAL].
# ============================================================================

# Application
APP=payments
NODE_ENV=development

# ============================================================================
# GRPC SERVER CONFIGURATION
# ============================================================================
# Host to bind the gRPC server to
# - 0.0.0.0 (all interfaces) for production
# - localhost for development
PAYMENTS_GRPC_HOST=0.0.0.0
PAYMENTS_GRPC_PORT=5001

# ============================================================================
# DATABASE
# ============================================================================
# Choose one: "postgres" (local Docker) or "neon" (serverless cloud)
DATABASE_PROVIDER=postgres

# PostgreSQL connection details (for local Docker Compose or Neon)
DATABASE_HOST=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rd_shop_payments_dev
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/rd_shop_payments_dev
