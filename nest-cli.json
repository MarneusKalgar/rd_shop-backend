{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/shop/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": false,
    "tsConfigPath": "apps/shop/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/shop",
  "projects": {
    "payments": {
      "type": "application",
      "root": "apps/payments",
      "entryFile": "main",
      "sourceRoot": "apps/payments/src",
      "compilerOptions": {
        "tsConfigPath": "apps/payments/tsconfig.app.json",
        "assets": [{ "include": "proto/*.proto", "watchAssets": false }]
      }
    },
    "shop": {
      "type": "application",
      "root": "apps/shop",
      "entryFile": "main",
      "sourceRoot": "apps/shop/src",
      "compilerOptions": {
        "tsConfigPath": "apps/shop/tsconfig.app.json",
        "deleteOutDir": true,
        "assets": [{ "include": "proto/*.proto", "watchAssets": false }]
      }
    }
  }
}
